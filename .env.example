# =========================================================
# 1. 飞书机器人基础凭证（必填）
# 用途：启动机器人、收发消息、创建群聊、读写飞书资源
# 来源：飞书开放平台应用的 App ID / App Secret
# =========================================================
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret

# =========================================================
# 2. Aily AI 问答配置（必填）
# 用途：调用 Aily 生成 AI 回答
# 来源：
# - AILY_APP_ID / AILY_APP_SECRET：Aily 应用凭证
# - AILY_BOT_ID：实际执行回答的 Aily Bot ID
# - AILY_HOST：接口域名，通常保持默认
# - AILY_REQUEST_TIMEOUT：单次请求超时秒数
# =========================================================
AILY_APP_ID=cli_xxx
AILY_APP_SECRET=your_aily_app_secret
AILY_BOT_ID=spring_xxx
AILY_HOST=https://open.feishu.cn
AILY_REQUEST_TIMEOUT=20

# =========================================================
# 3. 飞书卡片回调配置（使用卡片按钮时必填）
# 用途：校验消息卡片按钮回调，例如“已解决”“转人工”
# 如果这两项为空，机器人收消息可能正常，但卡片按钮交互会失败
# 来源：飞书开放平台应用里的「消息卡片」配置
# =========================================================
FEISHU_CARD_VERIFICATION_TOKEN=
FEISHU_CARD_ENCRYPT_KEY=

# =========================================================
# 4. 人工转接 / 卡片按钮配置
# 用途：控制 AI 回复卡片下方显示哪些“转人工”按钮，以及每个按钮拉谁进群
# 格式：DEPARTMENT_序号=部门名|按钮名|图标|负责人open_id列表
# 说明：
# - 按序号顺序展示按钮
# - 负责人多个用英文逗号分隔
# - 按钮名可留空，默认使用部门名
# - 图标可留空，默认使用 🏢
# =========================================================
DEPARTMENT_1=产品咨询|产品咨询|🛠|ou_xxx
DEPARTMENT_2=技术支持|技术支持|💻|ou_xxx
DEPARTMENT_3=商务合作|商务合作|🤝|ou_xxx
DEPARTMENT_4=财务对账|财务对账|💰|ou_xxx

# =========================================================
# 5. 群范围与运行行为
# 用途：控制机器人在哪些群生效，以及运行时的基础行为
# =========================================================
# 允许触发的群聊 ID（多个用英文逗号分隔，为空则允许所有群）
ALLOWED_CHAT_IDS=
# 创建的服务群名称前缀
SERVICE_GROUP_PREFIX=服务群
# 服务群自动解散：空闲多久后发提醒（默认 300 秒 = 5 分钟）
AUTO_DISSOLVE_IDLE_SECONDS=300
# 用户确认解散后，倒计时多久删群（默认 60 秒 = 1 分钟）
AUTO_DISSOLVE_COUNTDOWN_SECONDS=60
# 发出提醒后，多久没人处理则兜底直接归档解散（默认 86400 秒 = 24 小时）
AUTO_DISSOLVE_FALLBACK_SECONDS=86400
# 自动解散后台检查间隔（默认 30 秒）
AUTO_DISSOLVE_CHECK_INTERVAL_SECONDS=30
# 归档触发词（@机器人 + 包含以下任一词即触发，逗号分隔）
RESOLVE_KEYWORDS=问题已解决,已解决,问题解决
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# =========================================================
# 6. 多维表格配置
# 用途：记录服务群归档、统计 AI / 人工处理结果
# 说明：
# - BITABLE_APP_TOKEN：多维表格应用 token，归档表和统计表共用
# - BITABLE_TABLE_ID：服务群聊天记录归档表
# - BITABLE_STATS_TABLE_ID：AI 解答 / 转人工 / 已解决统计表
# =========================================================
BITABLE_APP_TOKEN=app_token_xxx
BITABLE_TABLE_ID=tbl_xxx
BITABLE_STATS_TABLE_ID=tbl_xxx
